const axios = require('axios');

let baseURL = 'https://rxnav.nlm.nih.gov/REST/';
let searchURL = `${baseURL}rxcui.json?name=`;
let lookupURL = `${baseURL}rxcui/`;

async function searchMedicine(name) {
  const response = await axios.get(searchURL + encodeURIComponent(name));

  // Safely check if rxnormId exists
  const ids = response.data.idGroup?.rxnormId;
  if (!ids || ids.length === 0) {
    return null; // no medicine found
  }

  return ids[0]; // return the first RxCUI
}

async function lookupMedicine(rxcui) {
  const response = await axios.get(`${lookupURL}${rxcui}/properties.json`);
  return response.data.properties;
}

module.exports = { searchMedicine, lookupMedicine };