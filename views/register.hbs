<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet" href="/style.css">

  <title>Register</title>
</head>
<body>
 <section class="auth-section">
  <div class="auth-left">
    <div class="auth-brand">
      <a href="/" class="logo">Health<span>Node</span></a>
      <h2>Join the platform connecting healthcare</h2>
      <p>Thousands of patients, doctors, and pharmacists trust HealthNode to manage care — securely and efficiently.</p>
      <ul class="auth-perks">
        <li> End-to-end encrypted records</li>
        <li>Instant appointment booking</li>
        <li> Digital prescription management</li>
        <li>HIPAA compliant</li>
      </ul>
    </div>
  </div>

  <div class="auth-right">
    <div class="auth-card">
      <h1 class="auth-title">Create your account</h1>
      <p class="auth-sub">Choose your role to get started</p>

      {{#if error}}
        <div class="alert alert-error">{{error}}</div>
      {{/if}}

      <form action="/register" method="POST" class="auth-form" id="registerForm" novalidate>
           <select name="role" class="form-group">
            <option value="doctor">Doctor</option>
            <option value="patient">Patient</option>
            <option value="pharmacist">Pharmacist</option>
          </select>


        <div class="form-group">
          <label for="username">Full name</label>
          <input
            type="text"
            id="username"
            name="username"
            placeholder="Your full name"
            value="{{formData.name}}"
            required
          />
        </div>

        <div class="form-group">
          <label for="email">Email address</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="you@example.com"
            value="{{formData.email}}"
            required
          />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            placeholder="Create a strong password"
            required
          />
        </div>
        <button type="submit" class="form-submit">Create account</button>
      </form>
      <p class="auth-switch">Already have an account? <a href="/login">Sign in</a></p>
    </div>
  </div>
</section>
<script src="/main.js"></script>
</body>
</html>