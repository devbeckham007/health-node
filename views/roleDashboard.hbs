
<!DOCTYPE html>
<html>
<head>
  <!-- Bootstrap CSS -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
    integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC"
    crossorigin="anonymous"
  />
  <!-- Bootstrap JS -->
  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM"
    crossorigin="anonymous"
  ></script>
  <link rel="stylesheet" href="/dashboard.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
  <title>Dashboard</title>
</head>
<body>
  <div class="main-con d-flex">
    <!-- Sidebar -->
    <div class="side1 bg-dark text-white p-3">
      <h1 class="dash">
        <span class="dot">.</span>
        <i class="fas fa-home me-2"></i>DASHBOARD
      </h1>

      <a class="nav-link text-white mb-2" href="/medicines">
        <i class="fa-solid fa-prescription-bottle-medical"></i> Medicines
      </a>

      <a class="nav-link text-white mb-2" href="/prescriptions">
        <i class="fas fa-notes-medical me-2"></i> Prescriptions
      </a>

      <a class="nav-link text-white mb-2" href="/appointments">
        <i class="fas fa-calendar-check me-2"></i> Appointments
      </a>

      <form action="/logout" method="POST">
        <button class="btn btn-danger mt-3 w-100">
          <i class="fas fa-sign-out-alt me-2"></i> Logout
        </button>
      </form>
    </div>

    <!-- Main Content -->
       <div class="side2 flex-grow-1 p-4">
      <h1>Welcome, {{message.username}}</h1>
      <p>Your role: {{message.role}}</p>
      <p>Your email: {{message.email}}</p>
      <p>Your department: {{doctor.department}}</p>
{{#ifEquals message.role "doctor"}}
  <form action="/prescriptions" method="POST" class="mt-2">
    <select name="patientId" required class="form-control mb-1">
      {{#each patients}}
        <option value="{{this._id}}">{{this.username}} ({{this.email}})</option>
      {{/each}}
    </select>
  </form>
{{/ifEquals}}
    </div>
      <!-- Doctor-specific panel -->
      {{#ifEquals message.role "doctor"}}
        <div class="card mt-3">
          <div class="card-body">
            <h4>Doctor Profile</h4>
            <p><strong>Department:</strong> {{doctor.department}}</p>
            <p><strong>License Number:</strong> {{doctor.licenseNumber}}</p>
            <p><strong>Qualifications:</strong> {{doctor.qualifications}}</p>
            <p><strong>Years of Experience:</strong> {{doctor.yearsOfExperience}}</p>
            <p><strong>Consultation Fee:</strong> ₦{{doctor.consultationFee}}</p>
            <p><strong>Availability:</strong> {{doctor.availability}}</p>
          </div>
        </div>

        
      {{/ifEquals}}

      <!-- Patient-specific panel -->
      {{#ifEquals message.role "patient"}}
        <div class="card mt-3">
          <div class="card-body">
            <h4>Patient Panel</h4>
            <p>Upcoming Appointments: {{appointments.length}}</p>
            <p>Prescriptions: {{prescriptions.length}}</p>
          </div>
        </div>
      {{/ifEquals}}
    </div>
  </div>
</body>
</html> 