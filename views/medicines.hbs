<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link
  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
  rel="stylesheet"
  integrity="sha384-ENjdO4Dr2bkBIFxQpeoYz1CzA6pqlQ1Z1N3zD9y+5n0UjzB1z7nUjzB1z7nUjzB1z7nUjzB1"
  crossorigin="anonymous"
/>
    <link rel="stylesheet" href="medicine.css">
    <title>Medicines</title>
</head>
<body>
    <h2>Medicine List</h2>
<ul>
  {{#each medicines}}
    <li>
      {{this.name}} - ${{this.price}} (Stock: {{this.stock}})
      <form action="/medicines/update/{{this._id}}" method="POST">
        <input type="text" name="name" value="{{this.name}}" />
        <input type="text" name="description" value="{{this.description}}" />
        <input type="number" name="price" value="{{this.price}}" />
        <input type="number" name="stock" value="{{this.stock}}" />
        <button type="submit">Update</button>
      </form>
      <form action="/medicines/delete/{{this._id}}" method="POST">
        <button type="submit">Delete</button>
      </form>
    </li>
  {{/each}}
</ul>

<h3>Add Medicine</h3>
<form action="/medicines" method="POST">
  <input type="text" name="name" placeholder="Name" required />
  <input type="text" name="description" placeholder="Description" />
  <input type="number" name="price" placeholder="Price" />
  <input type="number" name="stock" placeholder="Stock" />
  <button type="submit">Add</button>
</form>
</body>
</html>