  <script src="/main.js"></script>
  <script>
    // Role pill switcher
    const pills = document.querySelectorAll('.pill');
    const roleDisplay = document.getElementById('role-display');
    const heroSub = document.getElementById('hero-sub');

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        pills.forEach(p => p.classList.remove('active'));
        pill.classList.add('active');

        const role = pill.dataset.role;
        const sub  = pill.dataset.sub;

        roleDisplay.classList.remove('in');
        roleDisplay.classList.add('out');

        setTimeout(() => {
          roleDisplay.textContent = role;
          heroSub.textContent = sub;
          roleDisplay.classList.remove('out');
          roleDisplay.classList.add('in');
        }, 350);
      });
    });

    // Auto-cycle roles
    let current = 0;
    const pillList = Array.from(pills);
    setInterval(() => {
      current = (current + 1) % pillList.length;
      pillList[current].click();
    }, 3500);
  </script>
</body>
</html>
