            <span class="dash-badge">Today</span>
          </div>
          <div class="stat-row">
            <div class="stat-box">
              <div class="stat-num">3</div>
              <div class="stat-label">Upcoming Appts</div>
            </div>
            <div class="stat-box">
              <div class="stat-num">12</div>
              <div class="stat-label">Lab Results</div>
            </div>
          </div>
          <div class="appointment-list">
            <div class="appt-item">
              <div class="appt-dot" style="background:#00B4A6;"></div>
              <div class="appt-info">
                <div class="appt-name">Dr. Amaka Obi</div>
                <div class="appt-time">Today · 10:30 AM</div>
              </div>
              <span class="appt-status" style="background:rgba(0,180,166,.15);color:#00B4A6;">Confirmed</span>
            </div>
            <div class="appt-item">
              <div class="appt-dot" style="background:#F5A623;"></div>
              <div class="appt-info">
                <div class="appt-name">Blood Test Results</div>
                <div class="appt-time">Ready to view</div>
              </div>
              <span class="appt-status" style="background:rgba(245,166,35,.15);color:#F5A623;">New</span>
            </div>
            <div class="appt-item">
              <div class="appt-dot" style="background:#7ab3ff;"></div>
              <div class="appt-info">
                <div class="appt-name">Prescription Refill</div>
                <div class="appt-time">Expires in 5 days</div>
              </div>
