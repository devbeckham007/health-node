        </div>

        <div class="testimonial-card">
          <div class="stars">★★★★★</div>
          <blockquote>"I used to dread coordinating with pharmacies. Now my prescriptions arrive digitally and everything is verified automatically."</blockquote>
          <div class="testimonial-author">
            <div class="author-avatar">CU</div>
            <div>
              <div class="author-name">Chidi Uchenna</div>
              <div class="author-role">Patient</div>
            </div>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="stars">★★★★★</div>
          <blockquote>"As a pharmacist, the referral code system makes verification instant. We've cut prescription errors by over 80%."</blockquote>
          <div class="testimonial-author">
            <div class="author-avatar">FB</div>
            <div>
              <div class="author-name">Fatima Bello</div>
              <div class="author-role">Chief Pharmacist, Lagos</div>
            </div>
          </div>
        </div>
      {{/if}}

    </div>
  </section>


  <!-- ══════════════════════════════════════
       CTA
  ══════════════════════════════════════ -->
