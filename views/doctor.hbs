<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <title>Complete Doctor Profile — HealthNode</title>
</head>
<body class="auth-page">

  <nav class="navbar">
    <a href="/" class="logo">Health<span>Node</span></a>
    <div class="nav-cta">
      <a href="/register" class="btn-ghost">← Back</a>
    </div>
  </nav>

  <div class="doctor-section">

    <div class="doctor-left">
      <div class="doctor-brand">
        <a href="/" class="logo">Health<span>Node</span></a>
        <h2>Almost there — complete your doctor profile</h2>
        <p>Add your credentials so patients can find and trust you. All information is verified before your profile goes live.</p>

        <div class="reg-steps">
          <div class="reg-step">
            <div class="step-circle done">✓</div>
            <div class="step-info">
              <strong>Account created</strong>
              <span>Email and password set</span>
            </div>
          </div>
          <div class="reg-step">
            <div class="step-circle active">2</div>
            <div class="step-info">
              <strong>Doctor profile</strong>
              <span>Credentials and availability</span>
            </div>
          </div>
          <div class="reg-step">
            <div class="step-circle todo">3</div>
            <div class="step-info">
              <strong>Verification</strong>
              <span>Review by HealthNode team</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="doctor-right">
      <div class="doctor-card">
        <h1 class="auth-title">Doctor profile</h1>
        <p class="auth-sub">Fill in your professional details to complete registration</p>

        <form action="/register/doctor/{{userId}}" method="POST" class="auth-form" novalidate>
          <div class="doctor-form-grid">

            <div class="form-group full">
              <label for="department">Department</label>
              <div class="select-wrap">
                <select name="department" id="department" required>
                  <option value="" disabled selected>Select your department…</option>
                  <option value="Cardiology">Cardiology</option>
                  <option value="Neurology">Neurology</option>
                  <option value="Pediatrics">Pediatrics</option>
                  <option value="Oncology">Oncology</option>
                  <option value="General Medicine">General Medicine</option>
                  <option value="Dermatology">Dermatology</option>
                  <option value="Orthopedics">Orthopedics</option>
                  <option value="Psychiatry">Psychiatry</option>
                  <option value="Obstetrics &amp; Gynecology">Obstetrics &amp; Gynecology</option>
                  <option value="Ophthalmology">Ophthalmology</option>
                </select>
              </div>
            </div>

            <div class="form-group full">
              <label for="email">Email address</label>
              <input type="email" id="email" name="email"
                placeholder="you@example.com" required />
            </div>
            <div class="form-group full">
              <label for="username">username</label>
              <input type="text" id="username" name="username"
                placeholder="Enter your username" required />
            </div>
            <div class="form-group full">
              <label for="licenseNumber">License number</label>
              <input type="text" id="licenseNumber" name="licenseNumber"
                placeholder="e.g. MDCN-12345" required />
            </div>

            <div class="form-group full">
              <label for="qualifications">Qualifications</label>
              <input type="text" id="qualifications" name="qualifications"
                placeholder="e.g. MBBS, MD, FMCP" required />
              <p class="hint">Separate multiple qualifications with commas</p>
            </div>

            <div class="form-group">
              <label for="yearsOfExperience">Years of experience</label>
              <input type="number" id="yearsOfExperience" name="yearsOfExperience"
                placeholder="e.g. 8" min="0" max="60" required />
            </div>

            <div class="form-group">
              <label for="consultationFee">Consultation fee (₦)</label>
              <input type="number" id="consultationFee" name="consultationFee"
                placeholder="e.g. 5000" min="0" required />
            </div>

            <div class="form-group full">
              <label for="maxAppointments">Max appointments per day</label>
              <input type="number" id="maxAppointments" name="maxAppointments"
                placeholder="e.g. 10" min="1" required />
            </div>

            <div class="form-group full">
              <label for="availability">Availability</label>
              <input type="text" id="availability" name="availability"
                placeholder="e.g. Mon–Fri, 9am–5pm" required />
            </div>

          </div>

          <button type="submit" class="form-submit" style="margin-top:10px;">Complete registration →</button>
        </form>

        <p class="auth-switch">Not a doctor? <a href="/register">Choose a different role</a></p>
      </div>
    </div>

  </div>

  <script src="/main.js"></script>
</body>
</html>
