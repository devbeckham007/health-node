<!-- DOCTOR DASHBOARD -->

<div class="dash-welcome">
  <div>
    <h1 class="dash-welcome-title">Good {{timeOfDay}}, Dr. {{lastName currentUser.name}} 👋</h1>
    <p class="dash-welcome-sub">You have <strong>{{stats.todayAppointments}}</strong> appointments scheduled today.</p>
  </div>
  <a href="/dashboard/prescriptions/new" class="btn-dash-primary">+ Write Prescription</a>
</div>

<!-- Stat cards -->
<div class="stat-cards">
  <div class="stat-card stat-card--teal">
    <div class="stat-card-icon">🧑‍⚕️</div>
    <div class="stat-card-body">
      <div class="stat-card-num">{{stats.totalPatients}}</div>
      <div class="stat-card-label">Total Patients</div>
    </div>
  </div>
  <div class="stat-card stat-card--amber">
    <div class="stat-card-icon">📅</div>
    <div class="stat-card-body">
      <div class="stat-card-num">{{stats.todayAppointments}}</div>
      <div class="stat-card-label">Today's Appointments</div>
    </div>
  </div>
  <div class="stat-card stat-card--blue">
    <div class="stat-card-icon">💊</div>
    <div class="stat-card-body">
      <div class="stat-card-num">{{stats.pendingPrescriptions}}</div>
      <div class="stat-card-label">Pending Prescriptions</div>
    </div>
  </div>
  <div class="stat-card stat-card--navy">
    <div class="stat-card-icon">💬</div>
    <div class="stat-card-body">
      <div class="stat-card-num">{{stats.unreadMessages}}</div>
      <div class="stat-card-label">Unread Messages</div>
    </div>
  </div>
</div>

<!-- Main grid -->
<div class="dash-grid">

  <!-- Today's schedule -->
  <div class="dash-card dash-card--wide">
    <div class="dash-card-header">
      <h2 class="dash-card-title">Today's Schedule</h2>
      <a href="/dashboard/appointments" class="dash-card-link">Full schedule →</a>
    </div>
    {{#if todayAppointments.length}}
      <div class="schedule-list">
        {{#each todayAppointments}}
        <div class="schedule-row">
          <div class="schedule-time-col">
            <div class="schedule-time">{{this.time}}</div>
            <div class="schedule-duration">{{this.duration}} min</div>
          </div>
          <div class="schedule-divider"></div>
          <div class="schedule-patient">
            <div class="appt-avatar">{{avatarInitials this.patientName}}</div>
            <div>
              <div class="schedule-patient-name">{{this.patientName}}</div>
              <div class="schedule-reason">{{this.reason}}</div>
            </div>
          </div>
          <div class="schedule-actions">
            <span class="status-badge status-badge--{{this.status}}">{{this.status}}</span>
            <a href="/dashboard/patients/{{this.patientId}}" class="btn-dash-sm">View Record</a>
          </div>
        </div>
        {{/each}}
      </div>
    {{else}}
      <div class="empty-state">
        <div class="empty-icon">📅</div>
        <p>No appointments scheduled for today</p>
      </div>
    {{/if}}
  </div>

  <!-- Recent patients -->
  <div class="dash-card">
    <div class="dash-card-header">
      <h2 class="dash-card-title">Recent Patients</h2>
      <a href="/dashboard/patients" class="dash-card-link">All patients →</a>
    </div>
    {{#if recentPatients.length}}
      <div class="patient-list">
        {{#each recentPatients}}
        <div class="patient-row">
          <div class="appt-avatar">{{avatarInitials this.name}}</div>
          <div class="patient-info">
            <div class="patient-name">{{this.name}}</div>
            <div class="patient-meta">Last visit: {{this.lastVisit}}</div>
          </div>
          <a href="/dashboard/patients/{{this._id}}" class="btn-dash-sm">Open</a>
        </div>
        {{/each}}
      </div>
    {{else}}
      <div class="empty-state">
        <div class="empty-icon">🧑‍⚕️</div>
        <p>No patients yet</p>
      </div>
    {{/if}}
  </div>

  <!-- Pending prescriptions -->
  <div class="dash-card">
    <div class="dash-card-header">
      <h2 class="dash-card-title">Pending Prescriptions</h2>
      <a href="/dashboard/prescriptions" class="dash-card-link">View all →</a>
    </div>
    {{#if pendingPrescriptions.length}}
      <div class="presc-list">
        {{#each pendingPrescriptions}}
        <div class="presc-row">
          <div class="presc-icon">💊</div>
          <div class="presc-info">
            <div class="presc-name">{{this.medication}}</div>
            <div class="presc-dosage">For: {{this.patientName}}</div>
          </div>
          <div class="presc-meta">
            <span class="status-badge status-badge--pending">Pending</span>
            <a href="/dashboard/prescriptions/{{this._id}}/approve" class="btn-dash-sm btn-dash-sm--teal">Approve</a>
          </div>
        </div>
        {{/each}}
      </div>
    {{else}}
      <div class="empty-state">
        <div class="empty-icon">💊</div>
        <p>No pending prescriptions</p>
      </div>
    {{/if}}
  </div>

  <!-- Messages -->
  <div class="dash-card">
    <div class="dash-card-header">
      <h2 class="dash-card-title">Messages</h2>
      <a href="/dashboard/messages" class="dash-card-link">View all →</a>
    </div>
    {{#if messages.length}}
      <div class="msg-list">
        {{#each messages}}
        <div class="msg-row {{#if this.unread}}msg-row--unread{{/if}}">
          <div class="msg-avatar">{{avatarInitials this.senderName}}</div>
          <div class="msg-body">
            <div class="msg-sender">{{this.senderName}}</div>
            <div class="msg-preview">{{this.preview}}</div>
          </div>
          <div class="msg-time">{{this.time}}</div>
        </div>
        {{/each}}
      </div>
    {{else}}
      <div class="empty-state">
        <div class="empty-icon">💬</div>
        <p>No messages yet</p>
      </div>
    {{/if}}
  </div>

</div>
